#!/usr/bin/env bash
# setup-bob-project — copy gstack skills into the current project workspace
#
# Bob's file sandbox only allows reading files within the project directory.
# Cross-skill references (e.g. /plan-ceo-review loading /office-hours) fail
# when the skills live at ~/.bob/skills/gstack/ outside the workspace.
#
# This script copies skill files into <project>/.bob/skills/gstack/ so bob
# can read them. The gstack preamble already detects this local directory:
#   [ -d "$_ROOT/.bob/skills/gstack" ] && GSTACK_ROOT="$_ROOT/.bob/skills/gstack"
#
# Usage: cd your-project && /path/to/gstack/setup-bob-project
# Re-run after: git pull && bun run gen:skill-docs --host bob
set -e

REPO_DIR="$(cd "$(dirname "$0")" && pwd -P)"
BOB_SKILLS_SOURCE="$REPO_DIR/.bob/skills"
BOB_RUNTIME="$HOME/.bob/skills/gstack"
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
PROJECT_GSTACK="$PROJECT_ROOT/.bob/skills/gstack"

echo "==> Checking prerequisites..."

# Prefer reading directly from the repo's generated .bob/skills/ directory —
# more reliable than ~/.bob/commands/ which may contain broken symlinks.
if [ ! -d "$BOB_SKILLS_SOURCE" ]; then
  echo "  .bob/skills/ not found in gstack repo — generating now..."
  (
    cd "$REPO_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host bob
  )
fi

if [ ! -d "$BOB_SKILLS_SOURCE" ]; then
  echo "Error: could not generate bob skill docs." >&2
  echo "  Try manually: cd $REPO_DIR && bun run gen:skill-docs --host bob" >&2
  exit 1
fi

echo "  source: $BOB_SKILLS_SOURCE"
echo "  target: $PROJECT_GSTACK"
echo ""

mkdir -p "$PROJECT_GSTACK"

# Copy each skill SKILL.md to .bob/skills/gstack/<skill-name>/SKILL.md.
# Generated dirs are named gstack-office-hours/ but the preamble references
# $GSTACK_ROOT/office-hours/SKILL.md — strip the leading "gstack-" prefix.
count=0
for skill_dir in "$BOB_SKILLS_SOURCE"/gstack*/; do
  [ -d "$skill_dir" ] || continue
  [ -f "$skill_dir/SKILL.md" ] || continue
  dir_name="$(basename "$skill_dir")"   # e.g. "gstack-office-hours" or "gstack"
  if [ "$dir_name" = "gstack" ]; then
    skill_name="gstack"
  else
    skill_name="${dir_name#gstack-}"    # "office-hours", "plan-ceo-review", etc.
  fi
  mkdir -p "$PROJECT_GSTACK/$skill_name"
  cp "$skill_dir/SKILL.md" "$PROJECT_GSTACK/$skill_name/SKILL.md"
  count=$((count + 1))
done

echo "==> Copied $count skill files."

# Symlink runtime dirs (bin, browse, gstack-upgrade) so GSTACK_BIN etc. resolve.
# These are shell-executed tools, not read_file calls — symlinks outside the
# workspace are fine for execution even if read_file would be blocked.
for asset in bin browse gstack-upgrade ETHOS.md review; do
  src="$BOB_RUNTIME/$asset"
  dst="$PROJECT_GSTACK/$asset"
  if [ -e "$src" ] && [ ! -e "$dst" ] && [ ! -L "$dst" ]; then
    ln -s "$src" "$dst"
  fi
done

echo "==> Runtime tools linked."

# Add .bob/ to the project's .gitignore
GITIGNORE="$PROJECT_ROOT/.gitignore"
if [ -f "$GITIGNORE" ]; then
  if ! grep -qxF ".bob/" "$GITIGNORE"; then
    echo ".bob/" >> "$GITIGNORE"
    echo "==> Added .bob/ to .gitignore"
  else
    echo "==> .bob/ already in .gitignore"
  fi
else
  echo ".bob/" > "$GITIGNORE"
  echo "==> Created .gitignore with .bob/"
fi

echo ""
echo "gstack skills ready for this project!"
echo "  $count skills in: $PROJECT_GSTACK"
echo "  bob will now load cross-skill files from within the workspace."
echo ""
echo "  Re-run after updating gstack:"
echo "    cd $REPO_DIR && git pull && $REPO_DIR/setup-bob-project"
echo ""
